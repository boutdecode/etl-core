{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "context7": {
      "type": "local",
      "command": ["npx", "-y", "@upstash/context7-mcp"],
      "enabled": true
    }
  },

  "mode": {
    "build": {
      "model": "github-copilot/claude-sonnet-4",
      "prompt": "docs/agent/prompt/build.md"
    },

    "plan": {
      "model": "github-copilot/gemini-2.5-pro",
      "prompt": "docs/agent/prompt/spec/plan.md",
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      }
    }
  }
}
